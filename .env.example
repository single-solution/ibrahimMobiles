# ============================================================================
# Mobile Store — Environment template
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored. Never commit real secrets.
# ============================================================================

# ----- Auth.js v5 ------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=replace-with-32-byte-base64-secret

# Public URL of the app (used by Auth.js for callbacks).
# Local dev: http://localhost:3000
# Production: https://your-domain.com
AUTH_URL=http://localhost:3000

# Trust the host header — required when running behind a reverse proxy.
AUTH_TRUST_HOST=true

# ----- Storefront base URL (SEO / sitemap / canonical links) ----------------
# Set to the public URL of the storefront in production. Falls back to
# AUTH_URL / VERCEL deployment URL when unset.
# STOREFRONT_BASE_URL=https://your-domain.com

# ----- MongoDB ---------------------------------------------------------------
# MongoDB connection string. The database name MUST be in the path.
# Example: mongodb+srv://user:pass@cluster.mongodb.net/mobile-store?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mobile-store?retryWrites=true&w=majority

# ----- OTP delivery (customer phone sign-in) --------------------------------
# Provider selection. Leave unset to auto-select Twilio when configured,
# else fall back to the console provider (dev only — prints OTPs to logs).
# Allowed values: "twilio", "console", or unset.
# OTP_PROVIDER=twilio

# Twilio credentials. Required to deliver real WhatsApp / SMS messages.
# https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# WhatsApp sender. Use Twilio's sandbox first ("whatsapp:+14155238886"),
# then your approved business sender once you go live.
TWILIO_WHATSAPP_FROM=

# SMS sender — must be SMS-capable for Pakistani destinations. A Twilio
# alphanumeric sender (e.g. "STORE") also works for one-way SMS in PK.
TWILIO_SMS_FROM=

# Optional kill-switches. Set either to "1" to disable a channel without
# removing the FROM env var.
# OTP_DISABLE_WHATSAPP=
# OTP_DISABLE_SMS=
