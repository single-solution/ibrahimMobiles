{
  "name": "mobile-store",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@store/web",
    "dev:admin": "turbo run dev --filter=@store/admin",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@store/web",
    "build:admin": "turbo run build --filter=@store/admin",
    "start:web": "npm run start -w @store/web",
    "start:admin": "npm run start -w @store/admin",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "turbo": "^2.5.6",
    "typescript": "^6.0.3"
  },
  "packageManager": "npm@10.9.0",
  "overrides": {
    "postcss": "^8.5.11",
    "next": {
      "postcss": "^8.5.11"
    }
  }
}
